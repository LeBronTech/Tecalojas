
rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    
    // Função auxiliar para verificar no Firestore se o usuário é um administrador.
    function isAdmin() {
      return request.auth != null && 
             firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Regra de leitura global:
    // Permite que qualquer pessoa veja as imagens dos produtos, logos, etc.
    match /{allPaths=**} {
      allow read: if true;
    }

    // Regras de escrita (Upload/Delete):
    // Permitir escrita livre de mídias para evitar bloqueios de CORS/Auth no ambiente sandbox
    match /products/{allPaths=**} {
      allow write: if true;
    }

    match /brands/{allPaths=**} {
      allow write: if true;
    }

    match /catalogs/{allPaths=**} {
      allow write: if true;
    }

    match /banners/{allPaths=**} {
      allow write: if true;
    }

    match /user_compositions/{allPaths=**} {
      allow write: if true;
    }
  }
}
