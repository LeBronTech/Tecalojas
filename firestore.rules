
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
  
    // Função auxiliar para verificar se o usuário autenticado é um administrador.
    function isAdmin() {
      return request.auth != null && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // --- COLEÇÕES DE LEITURA E GRAVAÇÃO (Essenciais para Gestão de Estoque e Painel) ---

    // Configurações (Cores, Taxas, Metas):
    match /settings/{docId} {
      allow read, write: if true;
    }

    // Produtos: Todos podem ler e gerenciar o estoque.
    match /products/{docId} {
      allow read, write: if true;
    }
    
    // Marcas: Todos podem ler e gerenciar.
    match /brands/{docId} {
      allow read, write: if true;
    }
    
    // Catálogos PDF: Todos podem ler e gerenciar.
    match /catalogs/{docId} {
      allow read, write: if true;
    }
    
    // Categorias: Todos podem ler e gerenciar.
    match /categories/{docId} {
      allow read, write: if true;
    }

    // Banners: Todos podem ler e gerenciar.
    match /banners/{docId} {
      allow read, write: if true;
    }
    
    // --- COLEÇÕES PROTEGIDAS ---

    // Perfis de usuário:
    match /users/{userId} {
      allow read, write: if true;
    }

    // Composições salvas dos usuários:
    match /user_compositions/{userId} {
      allow read, write: if true;
    }

    // Solicitações de Venda (Pedidos):
    match /saleRequests/{requestId} {
      allow read, write: if true;
    }
  }
}
